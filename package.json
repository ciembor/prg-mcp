{
  "name": "prg-mcp",
  "version": "0.1.0",
  "private": false,
  "description": "MCP server for Poland's official National Register of Boundaries (PRG).",
  "author": {
    "name": "Maciej Ciemborowicz",
    "email": "maciej.ciemborowicz@gmail.com"
  },
  "license": "EUPL-1.2",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ciembor/prg-mcp.git"
  },
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "bin": {
    "prg-mcp": "dist/cli.js"
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "LICENSE",
    "NOTICE.md",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/main.ts src/cli.ts --format esm --dts --clean",
    "prepack": "pnpm build",
    "benchmark:stack": "node scripts/benchmark-spatial-stack.mjs",
    "benchmark:prg-2026": "node scripts/benchmark-prg-2026.mjs",
    "generate:feature": "mcp-craftsman generate feature",
    "quality": "mcp-craftsman quality",
    "test": "vitest run"
  },
  "dependencies": {
    "@loaders.gl/core": "4.4.3",
    "@loaders.gl/wkt": "4.4.3",
    "@mcp-craftsman/core": "^0.2.1",
    "@mcp-craftsman/node": "^0.2.1",
    "@mcp-craftsman/zod": "^0.2.1",
    "@turf/boolean-intersects": "7.3.5",
    "@turf/boolean-point-in-polygon": "7.3.5",
    "@turf/simplify": "7.3.5",
    "better-sqlite3": "12.11.1",
    "csv-parse": "7.0.0",
    "proj4": "2.20.9",
    "saxes": "6.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@mcp-craftsman/cli": "^0.2.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.0.3",
    "@vitest/coverage-v8": "^3.2.4",
    "dependency-cruiser": "^13.1.5",
    "eslint": "^9.29.0",
    "eslint-plugin-sonarjs": "^3.0.3",
    "knip": "^5.61.3",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
